# MinIO environment file
# Copy to .env and fill in your values.

# MinIO root credentials (used for initial setup and the mc client)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=REPLACE_ME

# The Docker internal network name of your Meet stack.
# Docker Compose names networks as <project>_<network>.
# If your meet stack lives in ~/docker/meet/, the internal network is 'meet_internal'.
# Adjust if your project directory has a different name.
MEET_INTERNAL_NETWORK=meet_internal
